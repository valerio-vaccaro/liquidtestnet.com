            <div class="well">
               <h3>What is Liquid testnet?</h3>
               It's a testnet for the Liquid sidechain.
               Liquid testnet requires Elements version 23.3.1 or newer.

               <h3>How to join?</h3>
               <pre>
chain=liquidtestnet

# Liquid Testnet (liquidtestnet) settings:
[liquidtestnet]

# General settings:
daemon=1
server=1
listen=1
txindex=1
addnode=liquid.network
addnode=liquid-testnet.blockstream.com
addnode=liquidtestnet.com

# liquidtestnet RPC settings (local RPC calls - optional):
rpcuser=user
rpcpassword=password
rpcport=18891
            </pre>
               <h3>Statistics</h3>
               <p>Height: {{height}}</p>
               <p>Mempool: {{mempool}}</p>
               <p>Disk space: {{space}}</p>
               <p>Board name: {{uname}}</p>
               <p>Uptime: {{uptime}}</p>

